{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "title": "Telegram",
  "description": "Send messages to a Telegram chat or group from an agent.",
  "x-tags": [
    "Communication",
    "Social"
  ],
  "properties": {
    "enabled": {
      "type": "boolean",
      "title": "Enabled",
      "description": "Whether this skill is enabled",
      "default": false
    },
    "states": {
      "type": "object",
      "description": "States for each Telegram skill (disabled, public, or private).",
      "properties": {
        "send_message": {
          "type": "string",
          "title": "Send Message",
          "enum": ["disabled", "public", "private"],
          "x-enum-title": ["Disabled", "Agent Owner + All Users", "Agent Owner Only"],
          "default": "disabled"
        }
      }
    },
    "bot_token": {
      "type": "string",
      "title": "Telegram Bot Token",
      "description": "Telegram bot token from BotFather.",
      "x-sensitive": true
    },
    "default_chat_id": {
      "type": "string",
      "title": "Default Chat ID",
      "description": "Telegram chat ID for the default destination group or channel."
    },
    "api_base_url": {
      "type": "string",
      "title": "Telegram API Base URL",
      "description": "Optional API base URL override for local and end-to-end testing.",
      "default": "https://api.telegram.org"
    }
  },
  "required": ["enabled", "states"],
  "if": {
    "properties": {
      "enabled": {
        "const": true
      }
    }
  },
  "then": {
    "required": ["bot_token", "default_chat_id"]
  },
  "additionalProperties": true
}
